{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/", "destination": "/roi-calculator.html" },
    { "source": "/uk", "destination": "/roi-calculator.html" },
    { "source": "/calc", "destination": "/roi-calculator.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
